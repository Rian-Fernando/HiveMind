# ── Supabase (free tier: supabase.com) ─────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI providers (both have free tiers, no credit card) ────────────
# Primary: Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key
# Fallback: Groq — https://console.groq.com/keys
GROQ_API_KEY=your-groq-key
